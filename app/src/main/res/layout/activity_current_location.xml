<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F1">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E7DDD3">

        <LinearLayout
            android:id="@+id/map_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_location_map_placeholder_title"
                android:textColor="#4A4039"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/map_placeholder_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/current_location_map_placeholder_body"
                android:textColor="#6C5E53"
                android:textSize="14sp" />

        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/button_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/back_button"
        android:elevation="6dp"
        android:fontFamily="sans-serif"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="0dp"
        android:text="@string/back_button_icon"
        android:textAllCaps="false"
        android:textSize="20sp" />

    <Button
        android:id="@+id/button_refresh_gps"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="86dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/gps_cta"
        android:elevation="8dp"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="0dp"
        android:text="@string/gps_button_icon"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:translationY="-50px" />

    <LinearLayout
        android:id="@+id/current_location_actions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/button_set_current_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#C96A18"
            android:elevation="8dp"
            android:padding="16dp"
            android:text="@string/set_current_location_cta"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/station_list_scrim_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="16dp"
        android:visibility="gone">

        <View
            android:id="@+id/station_list_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/station_list_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/station_list_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:id="@+id/station_list_drag_handle_touch_area"
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <View
                        android:id="@+id/station_list_drag_handle"
                        android:layout_width="96dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_station_sheet_handle" />
                </FrameLayout>

                <TextView
                    android:id="@+id/station_list_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="20dp"
                    android:text="@string/station_list_title"
                    android:textColor="#1F1A17"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/station_list_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingHorizontal="20dp"
                    android:text="@string/station_list_subtitle"
                    android:textColor="#6C5E53"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/station_list_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/station_list_empty"
                android:textColor="#6C5E53"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/station_list_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/station_info_scrim_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="16dp"
        android:visibility="gone">

        <View
            android:id="@+id/station_info_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000" />

        <LinearLayout
            android:id="@+id/station_info_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/station_info_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp"
                android:paddingHorizontal="20dp">

                <View
                    android:id="@+id/station_info_drag_handle"
                    android:layout_width="44dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_station_sheet_handle" />

                <TextView
                    android:id="@+id/station_info_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/station_info_title"
                    android:textColor="#1F1A17"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/station_info_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/station_info_subtitle_placeholder"
                    android:textColor="#6C5E53"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/station_info_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/station_info_body_placeholder"
                android:textColor="#6C5E53"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
