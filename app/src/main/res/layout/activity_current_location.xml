<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F1">

    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E7DDD3">

        <LinearLayout
            android:id="@+id/map_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/current_location_map_placeholder_title"
                android:textColor="#4A4039"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/map_placeholder_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/current_location_map_placeholder_body"
                android:textColor="#6C5E53"
                android:textSize="14sp" />

        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/button_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/back_button"
        android:elevation="6dp"
        android:fontFamily="sans-serif"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="0dp"
        android:text="@string/back_button_icon"
        android:textAllCaps="false"
        android:textSize="20sp" />

    <LinearLayout
        android:id="@+id/zoom_controls_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="152dp"
        android:elevation="8dp"
        android:orientation="vertical"
        android:translationY="-120px">

        <Button
            android:id="@+id/button_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/zoom_in_cta"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:padding="0dp"
            android:text="@string/zoom_in_icon"
            android:textAllCaps="false"
            android:textSize="20sp" />

        <Button
            android:id="@+id/button_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/zoom_out_cta"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:padding="0dp"
            android:text="@string/zoom_out_icon"
            android:textAllCaps="false"
            android:textSize="20sp" />
    </LinearLayout>

    <Button
        android:id="@+id/button_refresh_gps"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="86dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/gps_cta"
        android:elevation="8dp"
        android:minWidth="48dp"
        android:minHeight="48dp"
        android:padding="0dp"
        android:text="@string/gps_button_icon"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:translationY="-50px" />

    <LinearLayout
        android:id="@+id/current_location_actions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <Button
            android:id="@+id/button_set_current_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#C96A18"
            android:elevation="8dp"
            android:padding="16dp"
            android:text="@string/set_current_location_cta"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/station_list_scrim_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="16dp"
        android:visibility="gone">

        <View
            android:id="@+id/station_list_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/station_list_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/station_list_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:id="@+id/station_list_drag_handle_touch_area"
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <View
                        android:id="@+id/station_list_drag_handle"
                        android:layout_width="96dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_station_sheet_handle" />
                </FrameLayout>

                <TextView
                    android:id="@+id/station_list_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="20dp"
                    android:text="@string/station_list_title"
                    android:textColor="#1F1A17"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/station_list_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:paddingHorizontal="20dp"
                    android:text="@string/station_list_subtitle"
                    android:textColor="#6C5E53"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/station_list_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/station_list_empty"
                android:textColor="#6C5E53"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/station_list_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/station_info_scrim_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="16dp"
        android:visibility="gone">

        <View
            android:id="@+id/station_info_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <LinearLayout
            android:id="@+id/station_info_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/station_info_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp"
                android:paddingHorizontal="20dp">

                <View
                    android:id="@+id/station_info_drag_handle"
                    android:layout_width="44dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_station_sheet_handle" />

                <TextView
                    android:id="@+id/station_info_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/station_info_title"
                    android:textColor="#1F1A17"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/station_info_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/station_info_subtitle_placeholder"
                    android:textColor="#6C5E53"
                    android:textSize="13sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/station_info_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_station_list_item"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/station_info_brand_logo"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:contentDescription="@string/station_brand_logo_content_description"
                            android:scaleType="centerInside" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/station_info_name_label"
                                android:textColor="#8A7C71"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/station_info_name_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#1F1A17"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_address_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_address_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/station_info_phone_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_phone_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_fuel_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:id="@+id/station_info_fuel_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_route_distance_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_route_distance_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_cost_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:id="@+id/station_info_cost_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
