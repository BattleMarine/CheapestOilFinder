<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F1">

    <FrameLayout
        android:id="@+id/destination_map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E7DDD3">

        <LinearLayout
            android:id="@+id/map_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/destination_map_placeholder_title"
                android:textColor="#4A4039"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/map_placeholder_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/destination_map_placeholder_body"
                android:textColor="#6C5E53"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/button_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="20dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/back_button"
        android:padding="0dp"
        android:text="@string/back_button_icon"
        android:textAllCaps="false"
        android:textColor="#2F2A27"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/button_destination_gps"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/gps_cta"
            android:padding="0dp"
            android:text="@string/gps_button_icon"
            android:textAllCaps="false"
            android:textColor="#2F2A27"
            android:textSize="20sp" />

        <Button
            android:id="@+id/button_set_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#C96A18"
            android:padding="16dp"
            android:text="@string/set_destination_cta"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

</FrameLayout>
