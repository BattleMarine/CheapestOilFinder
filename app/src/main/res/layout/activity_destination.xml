<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F1">

    <FrameLayout
        android:id="@+id/destination_map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E7DDD3">

        <LinearLayout
            android:id="@+id/map_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/destination_map_placeholder_title"
                android:textColor="#4A4039"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/map_placeholder_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/destination_map_placeholder_body"
                android:textColor="#6C5E53"
                android:textSize="14sp" />

        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/destination_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp">

        <Button
            android:id="@+id/button_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/back_button"
            android:padding="0dp"
            android:text="@string/back_button_icon"
            android:textAllCaps="false"
            android:textColor="#2F2A27"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/destination_search_bar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_destination_search_bar"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#6C5E53" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/destination_search_bar_hint"
                android:textColor="#6C5E53"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/button_open_settings_overlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/settings_overlay_open"
            android:padding="0dp"
            android:text="@string/settings_overlay_icon"
            android:textAllCaps="false"
            android:textColor="#2F2A27"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/destination_zoom_controls_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="94dp"
        android:elevation="8dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/button_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/zoom_in_cta"
            android:padding="0dp"
            android:text="@string/zoom_in_icon"
            android:textAllCaps="false"
            android:textColor="#2F2A27"
            android:textSize="20sp" />

        <Button
            android:id="@+id/button_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:background="@drawable/bg_overlay_circle_button"
            android:contentDescription="@string/zoom_out_cta"
            android:padding="0dp"
            android:text="@string/zoom_out_icon"
            android:textAllCaps="false"
            android:textColor="#2F2A27"
            android:textSize="20sp" />
    </LinearLayout>

    <Button
        android:id="@+id/button_destination_gps"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_overlay_circle_button"
        android:contentDescription="@string/gps_cta"
        android:elevation="8dp"
        android:padding="0dp"
        android:text="@string/gps_button_icon"
        android:textAllCaps="false"
        android:textColor="#2F2A27"
        android:textSize="20sp" />

    <Button
        android:id="@+id/button_set_destination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:backgroundTint="#C96A18"
        android:elevation="18dp"
        android:padding="16dp"
        android:text="@string/set_destination_cta"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/destination_route_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000"
        android:clickable="true"
        android:elevation="42dp"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_destination_search_bar"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingVertical="24dp">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"
                android:indeterminateTint="#2563EB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/destination_route_loading_title"
                android:textColor="#1F1A17"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/destination_route_loading_body"
                android:textColor="#6C5E53"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/destination_search_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F1"
        android:clickable="true"
        android:elevation="48dp"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <Button
                android:id="@+id/button_search_overlay_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_overlay_circle_button"
                android:contentDescription="@string/search_overlay_close"
                android:padding="0dp"
                android:text="@string/back_button_icon"
                android:textAllCaps="false"
                android:textColor="#2F2A27"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/destination_search_overlay_title"
                android:textColor="#2F2A27"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edittext_destination_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_destination_search_bar"
                android:hint="@string/destination_search_input_hint"
                android:imeOptions="actionSearch"
                android:inputType="textPostalAddress"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:textColor="#2F2A27"
                android:textColorHint="#9A8A7E"
                android:textSize="16sp" />

            <Button
                android:id="@+id/button_destination_search_submit"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_overlay_circle_button"
                android:contentDescription="@string/destination_search_submit"
                android:padding="0dp"
                android:text="🔎"
                android:textAllCaps="false"
                android:textColor="#2F2A27"
                android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_destination_search_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="@string/destination_search_placeholder"
            android:textColor="#6C5E53"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_destination_autocomplete"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="12dp"
                android:scrollbars="vertical"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_destination_search_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="@string/destination_search_autocomplete_empty"
                android:textColor="#9A8A7E"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F1"
        android:clickable="true"
        android:elevation="64dp"
        android:focusable="true"
        android:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/button_settings_overlay_close"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_overlay_circle_button"
                        android:contentDescription="@string/back_button"
                        android:padding="0dp"
                        android:text="@string/back_button_icon"
                        android:textAllCaps="false"
                        android:textColor="#2F2A27"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_title"
                        android:textColor="#1F1A17"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/settings_overlay_subtitle"
                    android:textColor="#5F5147"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="@string/settings_fuel_type_label"
                    android:textColor="#3E3834"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinner_settings_overlay_fuel_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:spinnerMode="dropdown" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/settings_efficiency_label"
                    android:textColor="#3E3834"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_settings_overlay_fuel_efficiency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_placeholder_efficiency"
                    android:inputType="numberDecimal"
                    android:padding="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/settings_fuel_amount_label"
                    android:textColor="#3E3834"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_settings_overlay_refuel_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/settings_placeholder_fuel_amount"
                    android:inputType="numberDecimal"
                    android:padding="14dp" />

                <Button
                    android:id="@+id/button_settings_overlay_save"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:backgroundTint="#C96A18"
                    android:paddingVertical="14dp"
                    android:text="@string/settings_save_button"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/integrated_nearby_station_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="15dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/integrated_nearby_station_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:id="@+id/integrated_nearby_station_drag_handle_touch_area"
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <View
                        android:id="@+id/integrated_nearby_station_drag_handle"
                        android:layout_width="96dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_station_sheet_handle" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/integrated_nearby_station_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/integrated_nearby_station_title"
                        android:textColor="#1F1A17"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="end|center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/integrated_nearby_station_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="#6C5E53"
                            android:textSize="13sp" />

                        <Spinner
                            android:id="@+id/spinner_integrated_nearby_fuel_type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="136dp"
                            android:spinnerMode="dropdown" />

                        <Spinner
                            android:id="@+id/spinner_integrated_nearby_radius"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:minWidth="96dp"
                            android:spinnerMode="dropdown" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/integrated_nearby_station_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/integrated_nearby_station_empty"
                android:textColor="#6C5E53"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_integrated_nearby_stations"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/station_info_scrim_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="18dp"
        android:visibility="gone">

        <View
            android:id="@+id/station_info_scrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <LinearLayout
            android:id="@+id/station_info_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/station_info_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="14dp">

                <View
                    android:id="@+id/station_info_drag_handle"
                    android:layout_width="44dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_station_sheet_handle" />

                <TextView
                    android:id="@+id/station_info_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/station_info_title"
                    android:textColor="#1F1A17"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/station_info_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/station_info_subtitle_placeholder"
                    android:textColor="#6C5E53"
                    android:textSize="13sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/station_info_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_station_list_item"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/station_info_brand_logo"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:contentDescription="@string/station_brand_logo_content_description"
                            android:scaleType="centerInside" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/station_info_name_label"
                                android:textColor="#8A7C71"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/station_info_name_value"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#1F1A17"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/button_station_info_call"
                            android:layout_width="58dp"
                            android:layout_height="46dp"
                            android:background="@drawable/bg_external_map_button"
                            android:contentDescription="@string/station_info_call_button"
                            android:padding="0dp"
                            android:text="☎️"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/button_station_info_open_map"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_external_map_button"
                            android:contentDescription="@string/station_info_open_map_button"
                            android:text="@string/station_info_open_map_button"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_address_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_address_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/station_info_phone_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_phone_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_fuel_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:id="@+id/station_info_fuel_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_route_distance_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/station_info_route_distance_value"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#1F1A17"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_station_list_item"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/station_info_cost_label"
                            android:textColor="#8A7C71"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:id="@+id/station_info_cost_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/destination_search_results_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/destination_search_results_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:id="@+id/destination_search_results_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:id="@+id/destination_search_results_drag_handle_touch_area"
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <View
                        android:id="@+id/destination_search_results_drag_handle"
                        android:layout_width="96dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_station_sheet_handle" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/destination_search_results_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/destination_search_results_title"
                        android:textColor="#1F1A17"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/destination_search_results_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#6C5E53"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/destination_search_results_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/destination_search_results_empty"
                android:textColor="#6C5E53"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_destination_search_results"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/route_recommendation_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="17dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/route_recommendation_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_station_sheet"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="14dp">

                <FrameLayout
                    android:id="@+id/route_recommendation_drag_handle_touch_area"
                    android:layout_width="match_parent"
                    android:layout_height="44dp">

                    <View
                        android:id="@+id/route_recommendation_drag_handle"
                        android:layout_width="96dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_station_sheet_handle" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:id="@+id/route_recommendation_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/route_recommendation_title"
                        android:textColor="#1F1A17"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/route_recommendation_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#6C5E53"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/route_recommendation_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/route_recommendation_empty"
                android:textColor="#6C5E53"
                android:textSize="15sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_route_recommendations"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
