<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F1"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textColor="#1F1A17"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/home_subtitle"
        android:textColor="#5F5147"
        android:textSize="16sp" />

    <Button
        android:id="@+id/button_current_location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#C96A18"
        android:padding="16dp"
        android:text="@string/current_location_cta"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <Button
        android:id="@+id/button_destination"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="#F0D8C1"
        android:padding="16dp"
        android:text="@string/destination_cta"
        android:textAllCaps="false"
        android:textColor="#6A431A"
        android:textSize="18sp" />

    <Button
        android:id="@+id/button_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="#E5E1DC"
        android:padding="16dp"
        android:text="@string/settings_cta"
        android:textAllCaps="false"
        android:textColor="#3E3834"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/text_helper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/home_helper"
        android:textColor="#7A6A5F"
        android:textSize="14sp" />

</LinearLayout>
